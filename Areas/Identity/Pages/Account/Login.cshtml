@page
@model LoginModel

@{
    ViewData["Title"] = "Iniciar sesión";
}

<div class="login-page">
    <div class="login-card shadow-lg">
        <div class="login-header text-center">
            <h1 class="login-title">Iniciar sesión</h1>
            <p class="login-subtitle">Accede a tu cuenta para continuar</p>
        </div>

        <div class="row g-0">
            <div class="col-12 col-lg-7 login-form-section">
                <form id="account" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.Email" class="form-control login-input" autocomplete="username" aria-required="true" placeholder="correo@ejemplo.com" />
                        <label asp-for="Input.Email">Correo electrónico</label>
                        <span asp-validation-for="Input.Email" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.Password" class="form-control login-input" autocomplete="current-password" aria-required="true" placeholder="Contraseña" />
                        <label asp-for="Input.Password">Contraseña</label>
                        <span asp-validation-for="Input.Password" class="text-danger small"></span>
                    </div>

                    <div class="form-check mb-4">
                        <input class="form-check-input" asp-for="Input.RememberMe" />
                        <label asp-for="Input.RememberMe" class="form-check-label">
                            Recuérdame
                        </label>
                    </div>

                    <button id="login-submit" type="submit" class="btn btn-primary w-100 login-btn">
                        Ingresar
                    </button>

                    <div class="login-links mt-4 text-center">
                        <p class="mb-2">
                            <a id="forgot-password" asp-page="./ForgotPassword">¿Olvidaste tu contraseña?</a>
                        </p>
                        <p class="mb-2">
                            <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Crear una cuenta</a>
                        </p>
                        <p class="mb-0">
                            <a id="resend-confirmation" asp-page="./ResendEmailConfirmation">Reenviar confirmación de correo</a>
                        </p>
                    </div>
                </form>
            </div>

            <div class="col-12 col-lg-5 login-side-section">
                <div class="login-side-content">
                    <h3 class="mb-3">Bienvenido a TecKCL</h3>
                    <p class="mb-0">
                        Ingresa para revisar tus pedidos, gestionar tu cuenta y disfrutar de una mejor experiencia de compra.
                    </p>

                    @if ((Model.ExternalLogins?.Count ?? 0) > 0)
                    {
                        <hr class="my-4 text-white-50" />
                        <h5 class="mb-3">O también con</h5>

                        <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="d-flex flex-column gap-2">
                            @foreach (var provider in Model.ExternalLogins!)
                            {
                                <button type="submit" class="btn btn-outline-light" name="provider" value="@provider.Name" title="Inicia sesión usando tu cuenta de @provider.DisplayName">
                                    @provider.DisplayName
                                </button>
                            }
                        </form>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}