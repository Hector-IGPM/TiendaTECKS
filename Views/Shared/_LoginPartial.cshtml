@using Microsoft.AspNetCore.Identity
@using TiendaOnline.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav align-items-center">
    @if (SignInManager.IsSignedIn(User))
    {
        var usuario = await UserManager.GetUserAsync(User);
        var primerNombre = usuario?.PrimerNombre ?? "Usuario";

        <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle text-white fw-semibold"
                   href="#"
                   id="navbarUserDropdown"
                   role="button"
                   data-bs-toggle="dropdown"
                   aria-expanded="false">
                <i class="bi bi-person-circle me-1"></i> PRUEBA123 - @primerNombre
            </a>

            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="navbarUserDropdown">
                <li>
                    <a class="dropdown-item" asp-area="Identity" asp-page="/Account/Manage/Index">
                        Mi cuenta
                    </a>
                </li>
                <li><hr class="dropdown-divider" /></li>
                @if (SignInManager.IsSignedIn(User))
                {
                    <a asp-controller="Home" asp-action="Logout" class="nav-link text-danger">
                        Cerrar sesión
                    </a>
                }
            </ul>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="nav-link text-white" asp-area="Identity" asp-page="/Account/Register">Registrarse</a>
        </li>
        <li class="nav-item">
            <a class="nav-link text-white" asp-area="Identity" asp-page="/Account/Login">Iniciar sesión</a>
        </li>
    }
</ul>