<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TiendaOnline</title>

    <script type="importmap"></script>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TiendaOnline.styles.css" asp-append-version="true" />

    <link rel="icon" type="img/png" href="~/img/logo.png" />
    @RenderSection("Styles", required: false)
</head>
<body class="app-body">
    <header class="app-header">
        <nav class="navbar navbar-expand-lg app-navbar">
            <div class="container">
                <a class="navbar-brand app-navbar__brand" asp-area="" asp-controller="Home" asp-action="Index">
                    TecKCL
                </a>

                <button class="navbar-toggler app-navbar__toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                        aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 app-navbar__menu">
                        <li class="nav-item">
                            <a class="nav-link app-navbar__link" asp-area="" asp-controller="Home" asp-action="Privacy">Privacidad</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link app-navbar__link" href="#">Productos</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link app-navbar__link" href="#">Categorías</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link app-navbar__link" href="#">Contacto</a>
                        </li>
                    </ul>

                    <div class="app-navbar__actions">
                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="app-shell">
        <main role="main" class="app-main">
            @RenderBody()
        </main>
    </div>

    <footer class="app-footer">
        <div class="container app-footer__content">
            <div>
                <strong>TiendaOnline</strong>
                <span class="app-footer__text">© 2026 Todos los derechos reservados.</span>
            </div>

            <div class="app-footer__links">
                <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacidad</a>
                <a href="#">Términos</a>
                <a href="#">Contacto</a>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>