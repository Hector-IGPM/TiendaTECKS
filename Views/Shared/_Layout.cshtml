@using Microsoft.AspNetCore.Identity
@using TiendaOnline.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<!DOCTYPE html>

<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TiendaOnline</title>

    <script type="importmap"></script>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TiendaOnline.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/footer.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    
    <link rel="icon" type="image/png" href="~/img/logo.png" />
    @RenderSection("Styles", required: false)
</head>
<body class="app-body">
    <header class="app-header">
        <nav class="app-topbar">
            <div class="app-topbar__container">

                <div class="app-topbar__left">
                    <a class="app-topbar__brand" asp-area="" asp-controller="Home" asp-action="Index">
                        TecKCL
                    </a>

                    <div class="app-topbar__categories-wrapper">
                        <button type="button" class="app-topbar__categories" id="btnCategorias">
                            <i class="bi bi-list app-topbar__menu-icon"></i>
                            <span class="app-topbar__categories-text">Categorías</span>
                        </button>

                        <div class="app-topbar__dropdown" id="menuCategorias">

                            <div class="app-topbar__dropdown-group">
                                <button type="button" class="app-topbar__dropdown-item app-topbar__dropdown-toggle">
                                    <span class="app-topbar__dropdown-label">
                                        <i class="bi bi-phone"></i>
                                        <span>Celulares</span>
                                    </span>
                                </button>
                                <div class="app-topbar__submenu">
                                    <a href="#" class="app-topbar__submenu-item">Samsung</a>
                                    <a href="#" class="app-topbar__submenu-item">Xiaomi</a>
                                    <a href="#" class="app-topbar__submenu-item">Motorola</a>
                                    <a href="#" class="app-topbar__submenu-item">iPhone</a>
                                </div>
                            </div>

                            <div class="app-topbar__dropdown-group">
                                <button type="button" class="app-topbar__dropdown-item app-topbar__dropdown-toggle">
                                    <span class="app-topbar__dropdown-label">
                                        <i class="bi bi-pc-display"></i>
                                        <span>PC Armados</span>
                                    </span>
                                </button>
                                <div class="app-topbar__submenu">
                                    <a href="#" class="app-topbar__submenu-item">Gamer</a>
                                    <a href="#" class="app-topbar__submenu-item">Oficina</a>
                                    <a href="#" class="app-topbar__submenu-item">Streaming</a>
                                    <a href="#" class="app-topbar__submenu-item">Diseño</a>
                                </div>
                            </div>

                            <div class="app-topbar__dropdown-group">
                                <button type="button" class="app-topbar__dropdown-item app-topbar__dropdown-toggle">
                                    <span class="app-topbar__dropdown-label">
                                        <i class="bi bi-cpu"></i>
                                        <span>Componentes</span>
                                    </span>
                                </button>
                                <div class="app-topbar__submenu">
                                    <a href="#" class="app-topbar__submenu-item">Procesadores</a>
                                    <a href="#" class="app-topbar__submenu-item">Tarjetas de video</a>
                                    <a href="#" class="app-topbar__submenu-item">Memorias RAM</a>
                                    <a href="#" class="app-topbar__submenu-item">SSD</a>
                                </div>
                            </div>

                            <div class="app-topbar__dropdown-group">
                                <button type="button" class="app-topbar__dropdown-item app-topbar__dropdown-toggle">
                                    <span class="app-topbar__dropdown-label">
                                        <i class="bi bi-controller"></i>
                                        <span>Consolas</span>
                                    </span>
                                </button>
                                <div class="app-topbar__submenu">
                                    <a href="#" class="app-topbar__submenu-item">PlayStation</a>
                                    <a href="#" class="app-topbar__submenu-item">Xbox</a>
                                    <a href="#" class="app-topbar__submenu-item">Nintendo</a>
                                    <a href="#" class="app-topbar__submenu-item">Accesorios consola</a>
                                </div>
                            </div>

                            <div class="app-topbar__dropdown-group">
                                <button type="button" class="app-topbar__dropdown-item app-topbar__dropdown-toggle">
                                    <span class="app-topbar__dropdown-label">
                                        <i class="bi bi-joystick"></i>
                                        <span>Juegos</span>
                                    </span>
                                </button>
                                <div class="app-topbar__submenu">
                                    <a href="#" class="app-topbar__submenu-item">PC</a>
                                    <a href="#" class="app-topbar__submenu-item">PlayStation</a>
                                    <a href="#" class="app-topbar__submenu-item">Xbox</a>
                                    <a href="#" class="app-topbar__submenu-item">Nintendo</a>
                                </div>
                            </div>

                            <div class="app-topbar__dropdown-group">
                                <button type="button" class="app-topbar__dropdown-item app-topbar__dropdown-toggle">
                                    <span class="app-topbar__dropdown-label">
                                        <i class="bi bi-headphones"></i>
                                        <span>Accesorios</span>
                                    </span>
                                </button>
                                <div class="app-topbar__submenu">
                                    <a href="#" class="app-topbar__submenu-item">Audífonos</a>
                                    <a href="#" class="app-topbar__submenu-item">Teclados</a>
                                    <a href="#" class="app-topbar__submenu-item">Mouse</a>
                                    <a href="#" class="app-topbar__submenu-item">Sillas gamer</a>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>

                <div class="app-topbar__center">
                    <form class="app-topbar__search" method="get" asp-controller="Productos" asp-action="Index">
                        <i class="bi bi-search app-topbar__search-icon"></i>
                        <input type="text" name="buscar" placeholder="Busca lo que necesitas" />
                    </form>
                </div>


                <div class="dropdown">
                    @if (SignInManager.IsSignedIn(User))
                    {
                        <button class="btn btn-link nav-link dropdown-toggle text-decoration-none border-0"
                                type="button"
                                data-bs-toggle="dropdown"
                                aria-expanded="false">

                            @{
                                var usuario = await UserManager.GetUserAsync(User);
                                var primerNombre = usuario?.Nombres?.Split(' ')[0];

                                if (string.IsNullOrWhiteSpace(primerNombre))
                                {
                                    primerNombre = "Usuario";
                                }
                            }

                            <i class="bi bi-person-circle"></i> Hola, @primerNombre
                        </button>

                        <ul class="dropdown-menu dropdown-menu-end">
                            <li>
                                <a class="dropdown-item" href="#">Mi perfil</a>
                            </li>
                            <li>
                                <hr class="dropdown-divider" />
                            </li>
                            <li>
                                <a asp-controller="Home" asp-action="Logout" class="dropdown-item">
                                    Cerrar sesión
                                </a>
                            </li>
                        </ul>
                    }
                    else
                    {
                        <button class="btn btn-link nav-link dropdown-toggle text-decoration-none border-0" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-person-circle"></i> Hola, bienvenido
                        </button>

                        <ul class="dropdown-menu dropdown-menu-end">
                            <li>
                                <a class="dropdown-item" asp-area="Identity" asp-page="/Account/Login">Iniciar sesión</a>
                            </li>
                            <li>
                                <a class="dropdown-item" asp-area="Identity" asp-page="/Account/Register">Crear cuenta</a>
                            </li>
                        </ul>
                    }
                </div>

                <div class="app-topbar__right">
                    <a class="app-topbar__cart" href="#">
                        <i class="bi bi-cart3"></i>
                    </a>
                </div>

            </div>
        </nav>
    </header>

    <div class="app-shell">
        <main role="main" class="app-main">
            @RenderBody()
        </main>
    </div>

    <footer class="footer-tienda">
        <div class="footer-contenido">
        
            <div class="footer-col">
                <h4>TecKCL</h4>
                <p>© 2026 Todos los derechos reservados.</p>
                <ul class="footer-links">
                    <li><a href="#">Privacidad</a></li>
                    <li><a href="#">Términos</a></li>
                    <li><a href="#">Contacto</a></li>
                </ul>
            </div>

            <div class="footer-col">
                <h4>Redes sociales</h4>
                <ul class="footer-links">
                    <li><a href="#"><i class="bi bi-facebook"></i> Facebook</a></li>
                    <li><a href="#"><i class="bi bi-instagram"></i> Instagram</a></li>
                    <li><a href="#"><i class="bi bi-twitter-x"></i> X</a></li>
                    <li><a href="#"><i class="bi bi-tiktok"></i> TikTok</a></li>
                </ul>
            </div>

            <div class="footer-col">
                <h4>Contacto</h4>
                <ul class="footer-info">
                    <li><i class="bi bi-telephone"></i> Teléfono: +56 57 2 123456</li>
                    <li><i class="bi bi-phone"></i> Celular: +56 9 8765 4321</li>
                    <li><i class="bi bi-envelope"></i> Email: contacto@tiendaonline.cl</li>
                    <li><i class="bi bi-geo-alt"></i> Dirección: Módulo Zofri N° 128, Iquique, Chile</li>
                </ul>
            </div>

            <div class="footer-col">
                <h4>Formas de pago</h4>
                <ul class="footer-links">
                    <li><i class="bi bi-credit-card"></i> Visa</li>
                    <li><i class="bi bi-credit-card-2-front"></i> Mastercard</li>
                    <li><i class="bi bi-wallet2"></i> Mercado Pago</li>
                    <li><i class="bi bi-paypal"></i> PayPal</li>
                </ul>
            </div>

        </div>

        <div class="footer-ticket">
            <a href="#" class="ticket-link">Ingrese su solicitud de ticket</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    <script>
            document.addEventListener("DOMContentLoaded", function () {
                const btnCategorias = document.getElementById("btnCategorias");
                const menuCategorias = document.getElementById("menuCategorias");

                if (btnCategorias && menuCategorias) {
                    btnCategorias.addEventListener("click", function (e) {
                        e.stopPropagation();
                        menuCategorias.classList.toggle("show");
                    });

                    document.addEventListener("click", function (e) {
                        if (!menuCategorias.contains(e.target) && !btnCategorias.contains(e.target)) {
                            menuCategorias.classList.remove("show");
                        }
                    });
                }
            });
    </script>

    
    <script>
            const btnUsuario = document.getElementById("btnUsuario");
            const menuUsuario = document.getElementById("menuUsuario");

            btnUsuario.addEventListener("click", function () {
                menuUsuario.style.display =
                    menuUsuario.style.display === "block" ? "none" : "block";
            });

            document.addEventListener("click", function (e) {
                if (!btnUsuario.contains(e.target) && !menuUsuario.contains(e.target)) {
                    menuUsuario.style.display = "none";
                }
            });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>