@model IEnumerable<TiendaOnline.Models.Entidades.Producto>

@{
    ViewData["Title"] = "Productos";
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="fw-bold">Nuestros Productos</h1>
        <p class="text-muted">Descubre los mejores productos disponibles en nuestra tienda</p>
    </div>

    <div class="row g-4">
        @if (Model != null && Model.Any())
        {
            @foreach (var producto in Model)
            {
                <div class="col-md-6 col-lg-4 col-xl-3">
                    <div class="card producto-card h-100 shadow-sm border-0">
                        <div class="producto-img-container">
                            <img src="@producto.ImagenUrl" class="card-img-top producto-img" alt="@producto.Nombre">
                        </div>

                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title fw-bold">@producto.Nombre</h5>

                            <p class="card-text text-muted small">
                                @(string.IsNullOrEmpty(producto.Descripcion)
                                    ? "Producto sin descripción disponible."
                                    : producto.Descripcion.Length > 90
                                        ? producto.Descripcion.Substring(0, 90) + "..."
                                        : producto.Descripcion)
                            </p>

                            <div class="mt-auto">
                                <p class="fw-bold fs-5 text-primary mb-3">
                                    $@producto.Precio.ToString("N0")
                                </p>

                                <div class="d-grid gap-2">
                                    <a asp-controller="Productos" asp-action="Detalle" asp-route-id="@producto.Id" class="btn btn-outline-dark">
                                        Ver detalle
                                    </a>
                                    <button class="btn btn-primary">
                                        Agregar al carrito
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="alert alert-info text-center">
                    No hay productos disponibles en este momento.
                </div>
            </div>
        }
    </div>
</div>