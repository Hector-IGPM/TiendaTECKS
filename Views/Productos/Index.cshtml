@model List<TiendaOnline.Models.Entidades.Producto>

@{
    ViewData["Title"] = "Productos";
}

<h1 class="mb-4">Catálogo de Productos</h1>

<div class="row">
    @foreach (var producto in Model)
    {
        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow-sm">
                <img src="@producto.ImagenUrl" class="card-img-top" alt="@producto.Nombre" style="height: 250px; object-fit: cover;" />

                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">@producto.Nombre</h5>

                    <p class="card-text text-muted">
                        @(producto.Categoria != null ? producto.Categoria.Nombre : "Sin categoría")
                    </p>

                    <p class="card-text">
                        @producto.Descripcion
                    </p>

                    <p class="fw-bold mt-auto">
                        $@producto.Precio.ToString("N0")
                    </p>
                </div>
            </div>
        </div>
    }
</div>